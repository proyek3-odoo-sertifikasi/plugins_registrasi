<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="student_document_template" name="Upload Dokumen Persyaratan Asesi">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-primary text-white py-3">
                                <h3 class="mb-0">Upload Dokumen Persyaratan</h3>
                            </div>
                            <div class="card-body p-4 p-md-5">
                                <t t-if="errors">
                                    <div class="alert alert-danger" role="alert">
                                        <strong>Periksa kembali data upload:</strong>
                                        <ul class="mb-0 mt-2">
                                            <t t-foreach="errors" t-as="error">
                                                <li><t t-esc="error"/></li>
                                            </t>
                                        </ul>
                                    </div>
                                </t>

                                <t t-if="success_message">
                                    <div class="alert alert-success" role="alert">
                                        Dokumen berhasil disimpan. Data Anda siap untuk proses verifikasi admin.
                                    </div>
                                </t>

                                <t t-if="student">
                                    <t t-if="templates">
                                        <div class="mb-4">
                                            <div class="small text-muted">Template yang dapat diunduh</div>
                                            <ul>
                                                <t t-foreach="templates" t-as="tfile">
                                                    <li><a t-att-href="'/my/registrasi/dokumen/template/%s' % tfile" t-esc="tfile"/></li>
                                                </t>
                                            </ul>
                                        </div>
                                    </t>
                                    <div class="mb-4">
                                        <div class="small text-muted">Nama Asesi</div>
                                        <div class="fw-bold"><t t-esc="student.full_name"/></div>
                                        <div class="small text-muted mt-2">Email</div>
                                        <div class="fw-semibold"><t t-esc="student.email"/></div>
                                    </div>

                                    <form method="POST" action="/my/registrasi/dokumen/submit" enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                        <t t-foreach="requirements" t-as="req">
                                            <div class="mb-4">
                                                <label class="form-label fw-semibold">
                                                    <t t-esc="req['label']"/> <span class="text-danger">*</span>
                                                </label>
                                                <input type="file"
                                                       class="form-control"
                                                       t-att-name="req['field']"
                                                       t-att-accept="req['accept']"/>
                                                <div class="form-text">
                                                    Format diperbolehkan: <t t-esc="req.get('accept_label', 'PDF')"/> (maks. 7MB)
                                                </div>
                                                <t t-if="existing_files.get(req['field'])">
                                                    <div class="small text-success mt-1">
                                                        File saat ini: <t t-esc="existing_files.get(req['field'])"/>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>

                                        <div class="d-flex gap-2 mt-4">
                                            <button type="submit" class="btn btn-primary flex-grow-1">
                                                Simpan Dokumen
                                            </button>
                                            <a href="/" class="btn btn-outline-secondary">Kembali ke Website</a>
                                        </div>
                                    </form>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
