<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_registrasi_asesi_list" model="ir.ui.view">
    <field name="name">registrasi.asesi.list</field>
    <field name="model">registrasi.asesi</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="identity_number"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_registrasi_asesi_form" model="ir.ui.view">
    <field name="name">registrasi.asesi.form</field>
    <field name="model">registrasi.asesi</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="identity_number"/>
            <field name="email"/>
            <field name="phone"/>
            <field name="state"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_registrasi_asesi" model="ir.actions.act_window">
    <field name="name">Asesi</field>
    <field name="res_model">registrasi.asesi</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_plugins_registrasi_root" name="Data Asesi" sequence="80"/>
  <menuitem id="menu_registrasi_asesi" name="Data Asesi" parent="menu_plugins_registrasi_root" action="action_lsp_student"/>
</odoo>
